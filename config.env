# =============================================================================
# Treble Overlay — Device Configuration
# =============================================================================
# TEMPLATE — Edit for YOUR device, then run: ./build.sh
#
# HOW THESE VALUES ARE USED:
#   ┌─────────────────────┬────────────────────────────────────────────────┐
#   │ Category            │ What it controls                               │
#   ├─────────────────────┼────────────────────────────────────────────────┤
#   │ OVERLAY_NAME/PKG   │ Output filenames, AndroidManifest.xml (package) │
#   │ DEVICE_PROP_*       │ Overlay activation condition (ro.product.*)    │
#   │ HAS_* flags         │ Module description + generated.xml (overlay)   │
#   │ ROUNDED_* / HEIGHT  │ generated.xml → resource values in APK         │
#   │ UDFPS_*             │ generated.xml + service.sh (UDFPS coords)      │
#   │ BRIGHTNESS_*        │ generated.xml → brightness resource values     │
#   │ BATTERY_*           │ Documentation only (edit power_profile.xml)    │
#   │ PLATFORM_*          │ Build tools (aapt2 linking + signing)          │
#   └─────────────────────┴────────────────────────────────────────────────┘
#
# ⚠  IMPORTANT: Complex values (display cutout SVG, auto-brightness curves,
#    power_profile, sensor arrays, radio config) are in res/values/*.xml.
#    Edit those XML files directly for deeper customization.
#
# Steps:
#   1. Change OVERLAY_NAME to something unique for your device
#   2. Set DEVICE_PROP_VALUE to your device's codename
#   3. Adjust display/UDFPS values for your hardware
#   4. Set feature flags for your device (these become overlay resources)
#   5. Place vendor HAL files in system/vendor/ (see vendor_extraction_guide.md)
#   6. Run: ./build.sh
#
# Reference example: Samsung Galaxy A90 5G — see config.env.example
# =============================================================================

# ── Overlay identity ──────────────────────────────────────────────────────
# OVERLAY_NAME:       Output file prefix (e.g., treble-overlay-samsung-r3q.apk)
# OVERLAY_PACKAGE:    Android package name for the framework-res overlay APK (codename)
# OVERLAY_PACKAGE_SYSTEMUI: Package name for the SystemUI overlay APK (codename)
OVERLAY_NAME="treble-overlay-<your_device>"
OVERLAY_PACKAGE="me.phh.treble.overlay.<your_device>"
OVERLAY_PACKAGE_SYSTEMUI="me.phh.treble.overlay.<your_device>.systemui"

# ── Device matching ───────────────────────────────────────────────────────
# The overlay activates when DEVICE_PROP_NAME == DEVICE_PROP_VALUE at boot.
# Usually: ro.product.device = <codename>
# Find yours: adb shell getprop ro.product.device
DEVICE_PROP_NAME="ro.product.device" # no need to change
DEVICE_PROP_VALUE="<device_codename>"

# ── Android version ───────────────────────────────────────────────────────
# COMPILE_SDK_VERSION: API level for aapt2 link (e.g., 36 for Android 16, 35 for Android 15)
# ANDROID_VERSION:     Display version string (e.g., "16")
# MIN_SDK_VERSION:     minSdkVersion in AndroidManifest.xml
# TARGET_SDK_VERSION:  targetSdkVersion in AndroidManifest.xml
COMPILE_SDK_VERSION=36
ANDROID_VERSION="16"
MIN_SDK_VERSION=35
TARGET_SDK_VERSION=35

# ── Overlay priority ──────────────────────────────────────────────────────
# Higher = takes precedence over other overlays. 628 is the Phh-Treble default.
# SystemUI overlay uses 9999 to ensure doze config overrides all others.
OVERLAY_PRIORITY=628
OVERLAY_PRIORITY_SYSTEMUI=9999

# ── Device info (for banner display + module.prop name) ───────────────────
DEVICE_MANUFACTURER="<manufacturer>"
DEVICE_MODEL="<model_name>"
DEVICE_CODENAME="<codename>"

# ── Display geometry → generated.xml (overlays res/values/dimens.xml) ─────
# ROUNDED_CORNER_RADIUS:  Corner radius in pixels (e.g., 100)
# STATUS_BAR_HEIGHT:      Status bar height in pixels (e.g., 76)
ROUNDED_CORNER_RADIUS=100 (Configure for your device)
STATUS_BAR_HEIGHT=76 (Configure for your device)

# ⚠  QS_OFFSET_HEIGHT is now derived from STATUS_BAR_HEIGHT in generated.xml.
#    No need to set it separately.

# ── UDFPS Fingerprint → generated.xml + service.sh ────────────────────────
# HAS_UDFPS:       Set true if your device has an under-display fingerprint sensor (You might need to checkout vendor_extraction_guide.md to extract fingerprint services if UDFPS won't work)
# UDFPS_X/Y/RADIUS: Sensor position on screen in pixels
# HAS_SAMSUNG_FINGERPRINT: Set true for Samsung Goodix sensors (adds samsung_fingerprint prop)
# These values can't be off, even by 1. Make sure to get the exact values from device's vendor overlay or Device tree source
HAS_UDFPS=false
UDFPS_X=540 (Configure for your device)
UDFPS_Y=2145 (Configure for your device)
UDFPS_RADIUS=114 (Configure for your device)
HAS_SAMSUNG_FINGERPRINT=false

# ── Light sensor → generated.xml (overrides res/values/config.xml) ────────
# Find yours: adb shell dumpsys sensorservice | grep -i "Light Sensor"
HAS_AUTO_BRIGHTNESS=true
LIGHT_SENSOR_TYPE="<sensor_name>" (E.g samsung: com.samsung.sensor.physical_light)

# ── Refresh rate → generated.xml ──────────────────────────────────────────
DEFAULT_REFRESH_RATE=60
PEAK_REFRESH_RATE=60

# ── Battery capacity → documentation only (edit res/xml/power_profile.xml) ─
# ⚠  These do NOT auto-generate power_profile values. The power_profile.xml
#    is a structured XML with CPU cluster speeds/power, battery drain, etc.
#    It must be edited manually for your SoC.
BATTERY_CAPACITY=5000
BATTERY_TYPICAL_CAPACITY=5000

# ── Brightness calibration → generated.xml ────────────────────────────────
# These override values in res/values/config.xml. Defaults are safe minimums
# for an AMOLED panel. Adjust based on your device's panel characteristics.
BRIGHTNESS_DIM=15        # Minimum brightness before flicker (0-255)
BRIGHTNESS_DARK=3        # Auto-brightness floor (0-255)
BRIGHTNESS_DOZE=60       # AOD/doze brightness (0-255)
BRIGHTNESS_DEFAULT=128   # Default slider position (0-255)
BRIGHTNESS_MIN=0         # User-settable minimum (0-255)
BRIGHTNESS_MAX=255       # User-settable maximum (0-255)

# ── Feature flags → generated.xml (overrides res/values/bools.xml) ────────
# Each flag generates boolean resources in the overlay APK that tell the
# Android framework what features your device supports.
HAS_AOD=true                # Always-On Display support
HAS_DOZE=true               # Doze (deep sleep with notifications)
DOZE_SUSPEND_UNSUPPORTED=false  # Set true if hwcomposer crashes on DOZE_SUSPEND
HAS_5G=true                 # 5G NR support
HAS_VOLTE=true              # VoLTE / VoWiFi support
HAS_BURN_IN_PROTECTION=false # AMOLED burn-in prevention
HAS_DOUBLE_TAP_WAKE=false    # Double-tap to wake gesture

# ── Vendor HAL flags → module packaging + sepolicy ────────────────────────
# These control which HAL sections are included in customize.sh + service.sh.
# Actual HAL binary files must be placed in system/vendor/bin/hw/ etc.
HAS_VENDOR_FINGERPRINT_HAL=false (true if you are using service HALs)
HAS_VENDOR_VIBRATOR_HAL=false (true if you are using service HALs)

# ── Build tools ───────────────────────────────────────────────────────────
# PLATFORM_JAR:  Path to Android framework-res APK for aapt2 linking
# PLATFORM_KEY:  Path to platform private key for APK signing
# PLATFORM_CERT: Path to platform certificate for APK signing
PLATFORM_JAR="/usr/share/android-framework-res/framework-res.apk"
PLATFORM_KEY="keys/platform.pk8"
PLATFORM_CERT="keys/platform.x509.pem"
