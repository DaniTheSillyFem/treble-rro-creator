# =============================================================================
# Treble Overlay — Device Configuration (Example — Samsung A90 5G)
# =============================================================================
# This is a filled-in reference example for the Samsung Galaxy A90 5G (r3q).
# Copy this to config.env and adjust values for YOUR device, then run: ./build.sh
#
# Device specs: Snapdragon 855, 6.7" FHD+ Super AMOLED, UDFPS (Goodix ET715)
#
# 📖 Finding your values:
#   Device codename:  adb shell getprop ro.product.device
#   Manufacturer:     adb shell getprop ro.product.manufacturer
#   Model:            adb shell getprop ro.product.model
#   Android SDK:      adb shell getprop ro.build.version.sdk
#   Android version:  adb shell getprop ro.build.version.release
#   Light sensor:     adb shell dumpsys sensorservice | grep -i "Light Sensor"
#   Refresh rate:     adb shell settings system get peak_refresh_rate
#   Battery cap:      adb shell dumpsys batteryproperties | grep Capacity
#   All overlays:     adb shell cmd overlay list
#
# See config.env (the template) for detailed lookups for every variable.
# =============================================================================

OVERLAY_NAME="treble-overlay-samsung-r3q"
OVERLAY_PACKAGE="me.phh.treble.overlay.samsung.r3q"
OVERLAY_PACKAGE_SYSTEMUI="me.phh.treble.overlay.samsung.r3q.systemui"
DEVICE_PROP_NAME="ro.product.device"
DEVICE_PROP_VALUE="r3q"
COMPILE_SDK_VERSION=36
ANDROID_VERSION="16"
MIN_SDK_VERSION=35
TARGET_SDK_VERSION=35
OVERLAY_PRIORITY=628
OVERLAY_PRIORITY_SYSTEMUI=9999
DEVICE_MANUFACTURER="samsung"
DEVICE_MODEL="SM-A908N"
DEVICE_CODENAME="r3q"
ROUNDED_CORNER_RADIUS=100
STATUS_BAR_HEIGHT=76
HAS_UDFPS=true
UDFPS_X=540
UDFPS_Y=2145
UDFPS_RADIUS=114
HAS_SAMSUNG_FINGERPRINT=true
HAS_AUTO_BRIGHTNESS=true
LIGHT_SENSOR_TYPE="com.samsung.sensor.physical_light"
DEFAULT_REFRESH_RATE=60
PEAK_REFRESH_RATE=60
BATTERY_CAPACITY=5000
BATTERY_TYPICAL_CAPACITY=5000
BRIGHTNESS_DIM=15
BRIGHTNESS_DARK=3
BRIGHTNESS_DOZE=60
BRIGHTNESS_DEFAULT=128
BRIGHTNESS_MIN=0
BRIGHTNESS_MAX=255
HAS_AOD=true
HAS_DOZE=true
DOZE_SUSPEND_UNSUPPORTED=true   # Samsung hwcomposer can't handle DOZE_SUSPEND
HAS_5G=true
HAS_VOLTE=true
HAS_BURN_IN_PROTECTION=true
HAS_DOUBLE_TAP_WAKE=true
HAS_VENDOR_FINGERPRINT_HAL=true
HAS_VENDOR_VIBRATOR_HAL=true
PLATFORM_JAR="/usr/share/android-framework-res/framework-res.apk"
PLATFORM_KEY="keys/platform.pk8"
PLATFORM_CERT="keys/platform.x509.pem"
